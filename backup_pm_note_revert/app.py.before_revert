def _extract_pm_date(text):
    """Extract date from 'PM Note: Tue, June 02, 2026 at 5:32 PM ET' → '2026-06-02'."""
    m = re.search(r'PM Note:\s*\w+,\s*(\w+)\s+(\d{1,2}),\s*(\d{4})', text)
    if m:
        from datetime import datetime as _dt
        try:
            dt = _dt.strptime(f"{m.group(1)} {int(m.group(2)):02d} {m.group(3)}", "%B %d %Y")
            return dt.strftime("%Y-%m-%d")
        except ValueError:
            pass
    return None


@app.route("/api/parse-pm-pdf", methods=["POST"])
def parse_pm_pdf():
    if "file" not in request.files:
        return jsonify({"error": "No file uploaded"}), 400

    f = request.files["file"]
    if not f.filename.lower().endswith(".pdf"):
        return jsonify({"error": "File must be a PDF"}), 400

    try:
        with pdfplumber.open(io.BytesIO(f.read())) as pdf:
            pages = [page.extract_text() or "" for page in pdf.pages]
        text = "\n".join(pages).strip()
    except Exception as e:
        return jsonify({"error": f"PDF extraction failed: {e}"}), 500

    date_str = _extract_pm_date(text)
    if not date_str:
        return jsonify({"error": "date not found in PDF — expected line like 'PM Note: Tue, June 02, 2026 at 5:32 PM ET'"}), 400

    try:
        msg = _anthropic.messages.create(
            model="claude-sonnet-4-5",
            max_tokens=1024,
            timeout=30,
            messages=[{"role": "user", "content": _PM_PDF_PROMPT.format(text=text[:12000])}],
        )
        raw = msg.content[0].text.strip()
        cleaned = raw
        if "```" in cleaned:
            for part in cleaned.split("```"):
                part = part.strip()
                if part.startswith("json"):
                    part = part[4:].strip()
                if part.startswith("{"):
                    cleaned = part
                    break
        parsed = json.loads(cleaned.strip())
    except json.JSONDecodeError as e:
        return jsonify({"error": f"Claude returned invalid JSON: {e}", "raw": raw}), 200
    except Exception as e:
        return jsonify({"error": f"Claude API error: {e}"}), 500

    try:
        # Evita JSON/campo gigante vindo do Claude
        if isinstance(parsed.get("pm_levels_raw"), str):
            parsed["pm_levels_raw"] = parsed["pm_levels_raw"][:800]

        from journal import save_snapshot
        save_snapshot({
            "date":               date_str,
            "pm_note_summary":    parsed.get("pm_note_summary"),
            "pm_hiro":            parsed.get("pm_hiro"),
            "pm_vix_close":       parsed.get("pm_vix_close"),
            "pm_cor1m_close":     parsed.get("pm_cor1m_close"),
            "pm_market_comment":  parsed.get("pm_market_comment"),
            "pm_flow_comment":    parsed.get("pm_flow_comment"),
            "pm_vol_comment":     parsed.get("pm_vol_comment"),
            "next_events":        parsed.get("next_events"),
            "pm_levels_raw":      parsed.get("pm_levels_raw"),
        })
    except Exception as je:
        print(f"Journal auto-save warning (parse-pm-pdf): {je}")

    return jsonify({"ok": True, "date": date_str, **parsed})


