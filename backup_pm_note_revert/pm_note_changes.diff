+def _extract_pm_date(text):
+    """Extract date from 'PM Note: Tue, June 02, 2026 at 5:32 PM ET' → '2026-06-02'."""
+    m = re.search(r'PM Note:\s*\w+,\s*(\w+)\s+(\d{1,2}),\s*(\d{4})', text)
+    if m:
+        from datetime import datetime as _dt
+        try:
+            dt = _dt.strptime(f"{m.group(1)} {int(m.group(2)):02d} {m.group(3)}", "%B %d %Y")
+            return dt.strftime("%Y-%m-%d")
+        except ValueError:
+            pass
+    return None
+
